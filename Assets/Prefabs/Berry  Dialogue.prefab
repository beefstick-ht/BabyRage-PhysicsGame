  m_Script: {fileID: 11500000, guid: 60cbf9f0dc5a8db4abd0bd86bb04603f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  text: {fileID: 7861807287234823904}
  lines:
  - So I was telling Xerxes about my pond mortgage.. oh well hello there stranger.
  - To whatever may bring you to the dark woods I hope you are well prepared for
    the challenges ahead.
  - That gate over there is blocking our path towards...well our descent..
  - ' and it would seem as though we do not possess thumbs capable of lifting those
    oh so heavy boxes.'
  - It would save me oh so much squalor if one were to open the gate for me and the
    Mrs.
  textSpeed: 0.1
  index: 0
  typing: 0
  dialogueCam: {fileID: 0}
  player: {fileID: 0}
